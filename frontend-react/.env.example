# Optional: Django backend base URL (Render/Railway pe deployed).
# Set nahi kiya to app "standalone demo mode" me chalega — camera + AI
# poora kaam karega, bas login/history/save/PDF backend se nahi hoga.
VITE_API_URL=https://your-backend.onrender.com

# Sirf tab set karo agar WS URL http(s)->ws(s) auto-conversion se
# alag honi chahiye (rare case) — warna VITE_API_URL hi kaafi hai.
# VITE_WS_URL=wss://your-backend.onrender.com
